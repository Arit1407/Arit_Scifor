     "text": [
      "Enter rupees N which is sum of notes:26\n",
      "20 -> 1\n",
      "5 -> 1\n",
      "1 -> 1\n"
     ]
    }
   ],
   "source": [
    "notes=[1,2,5,10,20,50,100]\n",
    "N=int(input(\"Enter rupees N which is sum of notes:\"))\n",
    "notecount={}\n",
    "for note in notes[::-1]:\n",
    "    if N>=note:\n",
    "        notecount[note]=N//note\n",
    "        N=N%note\n",
    "for k,v in notecount.items():\n",
    "    print(\"{} -> {}\".format(k,v))\n",
    "    \n",
    "    "
   ]
  },
