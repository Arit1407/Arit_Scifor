   ],
   "source": [
    "mynum=input(\"Enter the number as a string:\")\n",
    "order=len(mynum)\n",
    "n=int(mynum)\n",
    "temp=n\n",
    "p=0\n",
    "while n>0:\n",
    "    rem=n%10\n",
    "    p=p+rem**order\n",
    "    n=n//10\n",
    "if temp==p:\n",
    "    print(mynum,\"is a Armstrong number\")\n",
    "else:\n",
    "    print(mynum,\"is not a Armstrong number\")"
   ]
  },
